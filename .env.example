# Porta que a interface web vai rodar
ERP_PORT=8501

# Caminho absoluto para o diretório de integração do ERP
# Em produção (Windows): c:/face-recognition/data/erp-integration
# Em desenvolvimento (Linux): ./data/erp-integration
ERP_INTEGRATION_PATH=./data/erp-integration

# Caminho do banco de dados SQLite (dentro do container)
ERP_DB_PATH=/app/data/erp.db

# URL do serviço face-recognition
FACIAL_URL=http://localhost:8080

# Timeout em segundos para aguardar resposta facial
POLL_TIMEOUT_S=300

# Intervalo de polling em segundos
POLL_INTERVAL_S=2
